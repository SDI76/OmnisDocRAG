# Copy this file to .env and fill in the values before running docker compose.

# ── PostgreSQL (running on host or external) ──────────────────
# On Windows/macOS with Docker Desktop, host.docker.internal resolves automatically.
# On Linux, the extra_hosts entry in docker-compose.yml handles this.
RAG_DB_HOST=host.docker.internal
RAG_DB_PORT=5432
RAG_DB_NAME=ragdb
RAG_DB_USER=rag_app
RAG_DB_PASS=change_me_app

# ── Embedding model ───────────────────────────────────────────
EMBED_MODEL=BAAI/bge-m3

# ── Ports (override if needed) ───────────────────────────────
RAG_PORT=7071
MCP_PORT=3000
