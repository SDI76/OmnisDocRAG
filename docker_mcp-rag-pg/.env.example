# Copy this file to .env before running the full dockerized stack.

# ── Published PostgreSQL port for imports and external tools ────────────────
# Keep 127.0.0.1 for local-only access, or use 0.0.0.0 if other machines
# should be able to connect to the database through this host.
POSTGRES_BIND_HOST=127.0.0.1
POSTGRES_HOST_PORT=5432
DOCKER_PG_HOST=127.0.0.1

# ── PostgreSQL container bootstrap ─────────────────────────────────────────
POSTGRES_DB=ragdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_postgres

# ── RAG application roles inside PostgreSQL ────────────────────────────────
RAG_DB_USER=rag_app
RAG_DB_PASS=change_me_app
RAG_DB_OWNER_PASS=change_me_owner
RAG_DB_RO_PASS=change_me_ro

# ── Embedding model + published service ports ──────────────────────────────
EMBED_MODEL=BAAI/bge-m3
RAG_PORT=7071
MCP_PORT=3000
