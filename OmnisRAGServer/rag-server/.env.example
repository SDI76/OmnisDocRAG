# Copy to .env and fill in your values

# ── PostgreSQL ───────────────────────────────────────────────
RAG_DB_HOST=192.168.1.xxx
RAG_DB_PORT=5432
RAG_DB_NAME=ragdb
RAG_DB_USER=rag_app
RAG_DB_PASS=

# ── Embedding model ──────────────────────────────────────────
EMBED_MODEL=BAAI/bge-m3

# ── Server ───────────────────────────────────────────────────
PORT=7071
STRICT_PORT=true
